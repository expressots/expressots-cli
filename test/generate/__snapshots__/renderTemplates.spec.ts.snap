exports[`generate templates opinionated renders config.tpl (v4) 1`] = `
"import { defineConfig, Env, loadEnvSync } from "@expressots/core";

/**
 * User Configuration
 *
 * Type-safe configuration with full TypeScript inference.
 * Features:
 * - Multi-environment defaults
 * - Secret management with auto-redaction
 * - Validation with helpful errors
 */

// Load environment files before config resolution
const envFiles = {
    development: ".env.local",
    production: ".env.prod",
};

loadEnvSync({ files: envFiles });

export const Config = defineConfig({
    // Add your configuration schema here
    enabled: Env.boolean("_ENABLED", {
        default: true,
        description: "Enable/disable User feature",
    }),
    // Example settings - customize as needed
    setting1: Env.string("_SETTING1", {
        default: "default-value",
    }),
    setting2: Env.number("_SETTING2", {
        default: 100,
        min: 0,
        max: 1000,
    }),
    bootstrap: {
        envFileConfig: {
            autoCreateTemplate: true,
            files: envFiles,
        },
    },
});

// Export typed config values
export const config = Config.values;
export type UserConfig = typeof config;

"
`;

exports[`generate templates opinionated renders controller-service-get.tpl 1`] = `
"import { controller, Get } from "@expressots/adapter-express";
import { inject } from "@expressots/core";
import { UserUseCase } from "./user.usecase";

@controller("/user")
export class UserController {
    @inject(UserUseCase) private userUseCase: UserUseCase;
	
    @Get("/")
    execute() {
        return this.userUseCase.execute();
    }
}
"
`;

exports[`generate templates opinionated renders controller-service-post.tpl 1`] = `
"import { body, controller, Post } from "@expressots/adapter-express";
import { inject } from "@expressots/core";
import { UserUseCase } from "./user.usecase";
import { IUserRequestDTO } from "./user.dto";

@controller("/user")
export class UserController {
    @inject(UserUseCase) private userUseCase: UserUseCase;

    @Post("/")
    execute(@body() payload: IUserRequestDTO) {
        return this.userUseCase.execute(payload);
    }
}
"
`;

