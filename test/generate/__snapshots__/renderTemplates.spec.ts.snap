exports[`generate templates opinionated renders interceptor.tpl (v4) 1`] = `
"import {
    IInterceptor,
    ExecutionContext,
    CallHandler,
    Interceptor,
    provide,
} from "@expressots/core";

/**
 * User Interceptor
 *
 * Priority:  (lower = earlier execution)
 *
 * Usage:
 * @UseInterceptors(UserInterceptor)
 * @controller("/route")
 * export class MyController { }
 */
@Interceptor({ priority:  })
@provide(UserInterceptor)
export class UserInterceptor implements IInterceptor {
    async intercept(context: ExecutionContext, next: CallHandler) {
        const request = context.getRequest();

        // Pre-processing logic
        console.log(\`[User] Before handler\`, {
            method: request.method,
            path: request.path,
        });

        const startTime = Date.now();

        try {
            // Execute next interceptor or handler
            const result = await next.handle();

            // Post-processing logic
            const duration = Date.now() - startTime;
            console.log(\`[User] After handler\`, {
                duration: \`\${duration}ms\`,
            });

            return result;
        } catch (error) {
            console.error(\`[User] Handler error\`, error);
            throw error;
        }
    }
}

"
`;

